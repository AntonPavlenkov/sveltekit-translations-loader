{
	"name": "sveltekit-translations-loader",
	"version": "0.0.54",
	"description": "A powerful translation system for SvelteKit with automatic type generation and runtime injection",
	"author": "Anton Pavlenkov",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/AntonPavlenkov/sveltekit-translations-loader.git"
	},
	"homepage": "https://github.com/AntonPavlenkov/sveltekit-translations-loader#readme",
	"bugs": {
		"url": "https://github.com/AntonPavlenkov/sveltekit-translations-loader/issues"
	},
	"scripts": {
		"dev": "npm run prepack && vite dev",
		"build": "vite build && npm run prepack",
		"build:cli": "node build-cli.js",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && npm run build:cli && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "vitest run",
		"test:unit": "vitest",
		"test:watch": "vitest --watch",
		"test:coverage": "vitest run --coverage",
		"test:ui": "vitest --ui",
		"prepublishOnly": "npm run test && npm run build"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"bin": {
		"sveltekit-translations-loader": "./dist/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./plugin": {
			"types": "./dist/plugin/index.d.ts",
			"import": "./dist/plugin/index.js"
		},
		"./server": {
			"types": "./dist/server/index.d.ts",
			"import": "./dist/server/index.js"
		},
		"./helpers": {
			"types": "./dist/helpers/index.d.ts",
			"import": "./dist/helpers/index.js"
		}
	},
	"engines": {
		"node": ">=20"
	},
	"peerDependencies": {
		"@sveltejs/kit": "^2.0.0",
		"svelte": "^5.0.0",
		"vite": "^7.0.0 || ^8.0.0"
	},
	"peerDependenciesMeta": {
		"vite": {
			"optional": true
		}
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-node": "^5.5.6",
		"@sveltejs/kit": "^2.67.0",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.16",
		"@tailwindcss/vite": "^4.3.1",
		"@types/node": "^26.0.0",
		"esbuild": "^0.28.1",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.7.0",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"publint": "^0.3.21",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.62.0",
		"vite": "^8.1.0",
		"vitest": "^4.1.9"
	},
	"keywords": [
		"svelte",
		"sveltekit",
		"translations",
		"i18n",
		"internationalization",
		"typescript",
		"vite-plugin"
	]
}
